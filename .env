# =========================
# Server / Auth
# =========================
# Порт, на котором будет слушать Express
PORT=3000

# Секрет для подписи JWT-токенов
# (в src/middleware/auth.js: если не задан, будет fallback_secret)
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# =========================
# PostgreSQL (Sequelize)
# =========================
# Dialect (обычно оставляйте postgres)
DB_DIALECT=postgres

# Хост БД (например: localhost)
DB_HOST=localhost

# Порт PostgreSQL (обычно 5432)
DB_PORT=5433

# Имя БД
DB_NAME=repair_service

# Пользователь БД
DB_USER=postgres

# Пароль пользователя БД
DB_PASSWORD=4x24oqwpH
